generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum DeliveryChannel {
  EMAIL
  SMS
}

enum ResetStatus {
  PENDING
  USED
  EXPIRED
  LOCKED
}

model PasswordResetRequest {
  id            String          @id @default(cuid())
  userAccountId String
  UserAccount   UserAccount     @relation(fields: [userAccountId], references: [id])
  codeHash      String
  channel       DeliveryChannel
  createdAt     DateTime
  expiresAt     DateTime
  attempts      Int
  status        ResetStatus
}

model UserAccount {
  id                    String                 @id @default(cuid())
  name                  String
  username              String                 @unique
  email                 String                 @unique
  password              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  isDeleted             Boolean                @default(false)
  UserProfile           UserProfile?
  passwordResetRequests PasswordResetRequest[]
  posts                 Post[]
  postLikes             PostLike[]
}

model Post {
  id            String      @id @default(cuid())
  userAccountId String
  UserAccount   UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  content       String      @db.VarChar(300)
  sharesCount   Int         @default(0)
  likesCount    Int         @default(0)
  sharePostId   String?
  sharedFrom    Post?       @relation("PostShares", fields: [sharePostId], references: [id], onDelete: SetNull)
  shares        Post[]      @relation("PostShares")
  likes         PostLike[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PostLike {
  id            String      @id @default(cuid())
  userAccountId String
  postId        String
  UserAccount   UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  Post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userAccountId, postId])
}

model UserProfile {
  id            String      @id @default(cuid())
  userAccountId String      @unique
  bio           String?
  country       String?
  state         String?
  city          String?
  avatarUrl     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  UserAccount   UserAccount @relation(fields: [userAccountId], references: [id])
}
